# Stellar Horizon API
HORIZON_URL=https://horizon.stellar.org
HORIZON_STREAM_URL=https://horizon.stellar.org

# Network: testnet | mainnet
NETWORK=testnet

# Polling / streaming
POLL_INTERVAL_SECONDS=5
TRADE_HISTORY_LOOKBACK_DAYS=30

# Detection engine
BENFORD_MAD_THRESHOLD=0.015
RISK_SCORE_THRESHOLD=70

# Model artifacts
MODEL_DIR=./models

# Local RiskScore store used by run_pipeline.py and the local API (api/main.py)
LEDGERLENS_DB_PATH=./ledgerlens.db

# LedgerLens-core -> downstream services (other repos in the org)
# ledgerlens-api base URL (consumes scores produced by this pipeline)
LEDGERLENS_API_URL=http://localhost:8000

# ledgerlens-contracts: Soroban contract id for the on-chain risk registry
LEDGERLENS_SCORE_CONTRACT_ID=

# Soroban service account used to submit_score (keep secret, never commit)
LEDGERLENS_SERVICE_SECRET_KEY=

# Webhook alert system
# 32-byte base64-encoded AES-256-GCM key for encrypting subscriber HMAC secrets
# Generate with: python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
# LEDGERLENS_WEBHOOK_ENCRYPTION_KEY=
